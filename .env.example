# ============================================================================
# Trainer Advisor — Environment variables
#
# Copy this file to `.env.local` for development (gitignored). On the
# Hetzner box, the runtime `.env` lives next to docker-compose.yml and is
# populated from GitHub Actions secrets at deploy time.
#
# Source of truth for the schema: this file. Aplikacja powinna validować
# process.env via Zod (src/env.ts) i fail-fast jeśli czegoś brakuje.
#
# Generate random 32-byte hex secrets with:
#   openssl rand -hex 32
# ============================================================================

# ---- App ----
APP_URL=https://your-domain.example
NODE_ENV=production
PORT=3000

# ---- Database (Supabase Postgres Frankfurt) ----
# Pooled connection for app code (transaction mode, port 6543).
# MUST set prepare=false in postgres-js client per AGENTS.md.
SUPABASE_DATABASE_URL=postgresql://postgres:<password>@<project>.pooler.supabase.com:6543/postgres?pgbouncer=true
# Direct connection for drizzle-kit migrate ONLY (session mode, port 5432).
SUPABASE_DIRECT_URL=postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres

# ---- Better Auth ----
# 32-byte hex; rotate quarterly.
BETTER_AUTH_SECRET=
# Match APP_URL; Better Auth uses it for OAuth redirect URI assembly.
BETTER_AUTH_URL=https://your-domain.example

# ---- Google Calendar OAuth ----
# From Google Cloud Console → Credentials → OAuth 2.0 Client.
# Redirect URI configured there: https://<domain>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- OAuth refresh-token encryption (libsodium crypto_secretbox) ----
# 32-byte hex master key. NEVER commit. Rotate by re-encrypting all stored
# tokens during a maintenance window.
LIBSODIUM_MASTER_KEY=

# ---- Email sender (Resend) ----
# From Resend dashboard → API Keys. Scope: sending only.
RESEND_API_KEY=
# Must match a verified domain in Resend.
RESEND_FROM=trener@your-domain.example

# ---- Backups (Cloudflare R2) ----
# R2 is S3-compatible; AWS SDKs / `aws s3` CLI work with --endpoint-url.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=trainer-advisor-backups
# Encryption passphrase for `openssl enc -aes-256-cbc` on backup files.
# 32+ char random; stored separately from R2 creds in password manager.
R2_ENC_PASS=

# ---- Optional: Sentry (defer until first non-founder user) ----
# SENTRY_DSN=
