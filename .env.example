# ============================================================================
# Trainer Advisor — Environment variables
#
# Copy this file to `.env.local` for development (gitignored). On the
# Hetzner box, the runtime `.env` lives next to docker-compose.yml and is
# populated from GitHub Actions secrets at deploy time.
#
# Source of truth for the schema: this file. Application MUST validate via
# Zod (`src/env.ts`) and fail-fast if anything is missing or malformed.
#
# Generate random 32-byte hex secrets with:
#   openssl rand -hex 32
# ============================================================================

# ---- App ----
APP_URL=http://localhost:3000
NODE_ENV=development
PORT=3000

# ---- Database (Supabase Postgres, Central EU Frankfurt) ----
# Pooled connection for app code (transaction-mode Supavisor pooler, port 6543).
# Newer Supavisor v2 does NOT need ?pgbouncer=true in URL (handled server-side).
# postgres-js MUST set prepare: false per AGENTS.md.
SUPABASE_DATABASE_URL=postgresql://postgres.<project>:<password>@aws-1-eu-central-1.pooler.supabase.com:6543/postgres
# Direct connection for drizzle-kit migrate ONLY (port 5432).
SUPABASE_DIRECT_URL=postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres

# ---- Better Auth ----
# Google as SOLE identity provider — emailAndPassword.enabled: false per FR-001.
# 32-byte hex; rotation invalidates all sessions.
BETTER_AUTH_SECRET=
# Match APP_URL; Better Auth uses it for OAuth redirect URI assembly.
BETTER_AUTH_URL=http://localhost:3000

# ---- Google OAuth (Calendar API) ----
# From Google Cloud Console → Credentials → OAuth 2.0 Client.
# Redirect URI configured there: <APP_URL>/api/auth/callback/google
# Scope requested: https://www.googleapis.com/auth/calendar.events.readonly
# Set up in S-01 (first slice using OAuth); empty placeholders during F-02 are OK.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- OAuth refresh-token encryption (libsodium crypto_secretbox) ----
# 32-byte hex master key. NEVER commit. BACK UP to password manager —
# losing this key orphans every encrypted refresh token.
LIBSODIUM_MASTER_KEY=

# ---- pg_cron + pg_net auth gate ----
# Bearer token checked by /api/sync route handler. Same value must be plugged
# into the pg_cron job SQL (drizzle/manual/0001_pg_cron_sync.sql) post-deploy.
PG_NET_TOKEN=

# ---- Backups (Cloudflare R2 — F-03 setup) ----
# R2 is S3-compatible; AWS SDKs / `aws s3` CLI work with --endpoint-url.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=trainer-advisor-backups
# Encryption passphrase for `openssl enc -aes-256-cbc` on backup files.
# 32+ char random; stored separately from R2 creds in password manager.
R2_ENC_PASS=

# ---- Optional: Sentry (defer until first non-founder user) ----
# SENTRY_DSN=
